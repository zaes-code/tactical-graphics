{
  "arrowParens": "avoid",
  "bracketSpacing": false,
  "endOfLine": "lf",
  "htmlWhitespaceSensitivity": "css",
  "printWidth": 150,
  "proseWrap": "preserve",
  "requirePragma": false,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 4,
  "trailingComma": "all",
  "useTabs": false,
  "overrides": [
    {
      "files": [
        "*.json",
        "*.css",
        "*.scss",
        "*.sass"
      ],
      "options": {
        "printWidth": 200,
        "tabWidth": 2
      }
    },
    {
      "files": "*.yml",
      "options": {
        "tabWidth": 2,
        "useTabs": false,
        "singleQuote": false,
        "trailingComma": "none"
      }
    }
  ]
}
